{% extends 'base.html.twig' %}

{% block title %}{{ course.title }} - Knowledge Learning{% endblock %}

{% block body %}
    <div style="margin-top: 50px;">
        <a href="{{ path('app_theme_show', {'id': course.theme.id}) }}" class="btn" style="background-color: #384050; margin-bottom: 20px;">
            &larr; Back to {{ course.theme.name }}
        </a>

        <h2 style="color: #00497c; border-bottom: 2px solid #0074c7; padding-bottom: 10px;">
            Lessons in: {{ course.title }}
        </h2>
        
        <p style="font-size: 1.2rem; margin-bottom: 30px;">
            Full course price: <strong style="color: #82b864;">{{ course.price }} €</strong>
        </p>

        <div class="card-grid">
            {% for lesson in course.lessons %}
                <div class="card">
                    <h3>{{ lesson.title }}</h3>
                    <p style="font-size: 1.2rem; font-weight: bold; color: #82b864;">Price: {{ lesson.price }} €</p>
                    <a href="{{ path('app_lesson_show', {'id': lesson.id}) }}" class="btn btn-success">View Lesson</a>
                </div>
            {% else %}
                <p>No lessons available for this course yet.</p>
            {% endfor %}
        </div>
    </div>
{% endblock %}