{% extends 'base.html.twig' %}

{% block title %}My Dashboard - Knowledge Learning{% endblock %}

{% block body %}
<div style="margin-top: 50px;">
    <h2 style="color: #00497c; border-bottom: 2px solid #0074c7; padding-bottom: 10px;">My Progress</h2>

    {% for theme in userProgress %}
        <div style="background-color: white; padding: 20px; border-radius: 8px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); margin-bottom: 30px;">
            <div style="display: flex; justify-content: space-between; align-items: center;">
                <h3 style="color: #00497c;">Theme: {{ theme.themeName }}</h3>
                {% if theme.isCertified %}
                    <span style="background-color: #ffd700; color: #000; padding: 8px 15px; border-radius: 20px; font-weight: bold; border: 2px solid #b8860b;">
                        🏆 CERTIFIED
                    </span>
                {% endif %}
            </div>

            <div class="card-grid" style="margin-top: 20px;">
                {% for course in theme.courses %}
                    <div class="card" style="border-color: {{ course.isCompleted ? '#82b864' : '#0074c7' }};">
                        <h4>{{ course.title }}</h4>
                        <div style="background-color: #eee; border-radius: 10px; height: 10px; margin: 15px 0;">
                            <div style="background-color: #82b864; height: 100%; border-radius: 10px; width: {{ course.progress }}%;"></div>
                        </div>
                        <p>{{ course.progress }}% Completed</p>
                        {% if course.isCompleted %}
                            <p style="color: #82b864; font-weight: bold;">✓ Course Validated</p>
                        {% endif %}
                    </div>
                {% endfor %}
            </div>
        </div>
    {% endfor %}
</div>
{% endblock %}