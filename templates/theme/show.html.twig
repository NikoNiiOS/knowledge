{% extends 'base.html.twig' %}

{% block title %}{{ theme.name }} Courses - Knowledge Learning{% endblock %}

{% block body %}
    <div style="margin-top: 50px;">
        <a href="{{ path('app_home') }}" class="btn" style="background-color: #384050; margin-bottom: 20px;">&larr; Back to Themes</a>

        <h2 style="color: #00497c; border-bottom: 2px solid #0074c7; padding-bottom: 10px;">
            Courses in {{ theme.name }}
        </h2>

        <div class="card-grid">
            {% for course in theme.courses %}
                <div class="card">
                    <h3>{{ course.title }}</h3>
                    <p style="font-size: 1.2rem; font-weight: bold; color: #82b864;">Price: {{ course.price }} €</p>
                    <a href="{{ path('app_course_show', {'id': course.id}) }}" class="btn btn-success">View Lessons</a>
                </div>
            {% else %}
                <p>No courses available in this theme yet.</p>
            {% endfor %}
        </div>
    </div>
{% endblock %}