{% extends 'base.html.twig' %}

{% block title %}{{ lesson.title }} - Knowledge Learning{% endblock %}

{% block body %}
    <div style="margin-top: 50px;">
        <a href="{{ path('app_course_show', {'id': lesson.course.id}) }}" class="btn" style="background-color: #384050; margin-bottom: 20px;">
            &larr; Back to {{ lesson.course.title }}
        </a>

        <h2 style="color: #00497c; border-bottom: 2px solid #0074c7; padding-bottom: 10px;">
            {{ lesson.title }}
        </h2>

        <div style="margin-bottom: 30px; margin-top: 20px;">
            {% if lesson.video %}
                <div style="text-align: center; margin-bottom: 30px;">
                    <iframe width="100%" height="500" src="{{ lesson.video }}" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen style="border-radius: 8px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); max-width: 800px;"></iframe>
                </div>
            {% endif %}

            <div style="background-color: white; padding: 2rem; border-radius: 8px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); line-height: 1.6;">
                {{ lesson.content|raw }}
            </div>
        </div>

        {% if not app.user %}
            <p style="margin-top: 15px; font-style: italic; color: #384050;">Log in to buy or validate this lesson.</p>
        {% else %}
        
            {% if not hasPurchased %}
                <a href="{{ path('app_checkout_lesson', {'id': lesson.id}) }}" class="btn" style="margin: 0 10px;">Buy this lesson</a>
            {% else %}
            
                <span style="display: inline-block; padding: 10px 20px; background-color: #e3f2fd; color: #1976d2; border: 1px solid #2196f3; border-radius: 4px; font-weight: bold; margin: 0 10px;">
                    🔓 Unlocked
                </span>
                
                {% if isValidated %}
                    <span style="display: inline-block; padding: 10px 20px; background-color: #e8f5e9; color: #2e7d32; border: 1px solid #4caf50; border-radius: 4px; font-weight: bold; margin: 0 10px;">
                        ✓ Lesson Validated
                    </span>
                {% else %}
                    <a href="{{ path('app_lesson_validate', {'id': lesson.id}) }}" class="btn btn-success" style="margin: 0 10px;">Validate this lesson</a>
                {% endif %}
                        
            {% endif %}

        {% endif %}
    </div>
{% endblock %}